---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  hideNav?: boolean;
}

const {
  title = 'Multidimensional Ideological Model',
  description = 'Explore 20 political ideologies in 3D space across 400 years of history.',
  hideNav = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/tool', label: 'Tool' },
  { href: '/quiz', label: 'Quiz' },
  { href: '/about', label: 'About' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#818cf8" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="MIM" />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icons/icon-192.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => navigator.serviceWorker.register('/sw.js'));
      }
    </script>
  </head>

  <body>
    {!hideNav && (
      <nav class="site-nav">
        <div class="nav-inner">
          <a href="/" class="nav-logo">
            <span class="logo-sphere"></span>
            <span class="logo-text">MIM</span>
          </a>

          <div class="nav-links" id="navLinks">
            {navLinks.map(link => {
              const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
              return (
                <a href={link.href} class={`nav-link${isActive ? ' nav-link--active' : ''}`}>
                  {link.label}
                </a>
              );
            })}
            <a href="/tool" class="nav-cta">Open Tool →</a>
          </div>

          <button class="hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
      </nav>
    )}

    <slot />

    {!hideNav && (
      <footer style="border-top:1px solid var(--color-border);padding:2.5rem 1.5rem;text-align:center;">
        <p style="color:var(--color-muted);font-size:0.8rem;margin:0;">
          Multidimensional Ideological Model · Open Source · Built by
          <a href="/about" style="color:var(--color-accent);text-decoration:none;">Guilherme Zeni</a>
          · <a href="https://github.com/Guillhermm/multidimensional-ideological-model" target="_blank" rel="noopener noreferrer" style="color:var(--color-accent);text-decoration:none;">GitHub</a>
        </p>
      </footer>
    )}

    <script is:inline>
      const hamburger = document.getElementById('hamburger');
      const navLinks = document.getElementById('navLinks');
      if (hamburger && navLinks) {
        hamburger.addEventListener('click', () => {
          const open = navLinks.classList.toggle('nav-links--open');
          hamburger.setAttribute('aria-expanded', open);
          hamburger.classList.toggle('hamburger--open', open);
        });
        // Close on outside click
        document.addEventListener('click', e => {
          if (!hamburger.contains(e.target) && !navLinks.contains(e.target)) {
            navLinks.classList.remove('nav-links--open');
            hamburger.setAttribute('aria-expanded', 'false');
            hamburger.classList.remove('hamburger--open');
          }
        });
      }
    </script>
  </body>
</html>

<style is:global>
  /* ─── Nav ─────────────────────────────────────── */
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(7, 7, 16, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-sphere {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: conic-gradient(#ef4444, #22c55e, #3b82f6, #ef4444);
    opacity: 0.9;
    flex-shrink: 0;
  }

  .logo-text {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    padding: 0.375rem 0.875rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.15s;
    color: var(--color-muted);
  }

  .nav-link--active {
    color: #fff;
    background: rgba(129, 140, 248, 0.15);
  }

  .nav-cta {
    margin-left: 0.5rem;
    padding: 0.375rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    background: var(--color-accent);
    color: #fff;
    transition: opacity 0.15s;
  }

  /* ─── Hamburger ────────────────────────────────── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 38px;
    height: 38px;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    cursor: pointer;
    padding: 7px;
    flex-shrink: 0;
  }

  .hamburger span {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--color-muted);
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
    transform-origin: center;
  }

  .hamburger--open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger--open span:nth-child(2) { opacity: 0; }
  .hamburger--open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ─── Mobile nav ────────────────────────────────── */
  @media (max-width: 599px) {
    .hamburger {
      display: flex;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      background: rgba(7, 7, 16, 0.97);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--color-border);
      padding: 0.625rem;
      gap: 0.25rem;
    }

    .nav-links--open {
      display: flex;
    }

    .nav-link {
      padding: 0.75rem 1rem;
      width: 100%;
    }

    .nav-cta {
      margin-left: 0;
      padding: 0.75rem 1rem;
      text-align: center;
      border-radius: 0.5rem;
    }
  }
</style>
