---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="3D Ideological Model — Tool"
  description="Interactive 3D visualization of political ideologies across history."
  hideNav={true}
>
  <style is:global>
    body { overflow: hidden; margin: 0; }
  </style>

  <!-- Quiz origin banner -->
  <div id="quizBanner" style="display:none;position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(129,140,248,0.18);backdrop-filter:blur(8px);border-bottom:1px solid rgba(129,140,248,0.25);padding:0.5rem 1rem;display:none;align-items:center;justify-content:space-between;font-size:0.8rem;color:var(--color-text);">
    <span>✓ Your position from the quiz has been applied.</span>
    <div style="display:flex;gap:1rem;align-items:center;">
      <a href="/quiz" style="color:var(--color-accent);text-decoration:none;font-weight:500;">Retake Quiz</a>
      <button onclick="this.parentElement.parentElement.remove()" style="background:none;border:none;color:var(--color-muted);cursor:pointer;font-size:1rem;padding:0;">×</button>
    </div>
  </div>

  <!-- Back link -->
  <a href="/" class="tool-back-link">← Home</a>

  <canvas id="canvas"></canvas>

  <!-- Mobile toggle button -->
  <button id="uiToggle" class="ui-toggle" aria-label="Toggle controls" aria-expanded="true">
    <span class="ui-toggle-icon">⚙</span>
    <span class="ui-toggle-label">Controls</span>
  </button>

  <div id="ui">
    <!-- Mobile drag handle -->
    <div class="ui-handle" id="uiHandle"></div>

    <h2 style="margin:0 0 1rem;font-size:1rem;font-weight:700;letter-spacing:-0.01em;">Ideological Atlas</h2>

    <div class="control">
      <label>Time: <span id="yearLabel"></span></label>
      <input type="range" id="timeSlider" />
    </div>

    <div class="control">
      <label>X — <span style="color:#ef4444;font-size:0.75em;">Economics</span></label>
      <input type="range" id="xSlider" min="-1" max="1" step="0.01" value="0">
    </div>

    <div class="control">
      <label>Y — <span style="color:#22c55e;font-size:0.75em;">Authority</span></label>
      <input type="range" id="ySlider" min="-1" max="1" step="0.01" value="0">
    </div>

    <div class="control">
      <label>Z — <span style="color:#3b82f6;font-size:0.75em;">Identity</span></label>
      <input type="range" id="zSlider" min="-1" max="1" step="0.01" value="0">
    </div>

    <div class="control">
      <label>Historical Gravity</label>
      <input type="range" id="gravitySlider" min="0" max="2" step="0.01" value="0.4">
    </div>

    <div class="control buttons">
      <button id="autoPlay">▶ Auto</button>
      <button id="exportPNG">📸 Export</button>
    </div>

    <div class="info">
      Year: <span class="year"></span><br>
      Instability: <span class="instability"></span><br>
      Radicality: <span class="radicality"></span><br>
      Nearest: <span class="nearest"></span>
    </div>

    <div class="ui-hints">
      Drag to rotate · Scroll to zoom<br>
      ← → ↑ ↓ keys · + / − zoom · 0 reset
    </div>
  </div>

  <!-- Load scripts in dependency order -->
  <script is:inline src="/scripts/core.js"></script>
  <script is:inline src="/scripts/projection.js"></script>
  <script is:inline src="/scripts/interaction.js"></script>
  <script is:inline src="/scripts/data.js"></script>
  <script is:inline src="/scripts/physics.js"></script>
  <script is:inline src="/scripts/clustering.js"></script>
  <script is:inline src="/scripts/rendering.js"></script>
  <script is:inline src="/scripts/time.js"></script>
  <script is:inline src="/scripts/main.js"></script>

  <!-- URL params: apply quiz results to sliders -->
  <script is:inline>
    (function () {
      const params = new URLSearchParams(window.location.search);
      const clamp = v => Math.max(-1, Math.min(1, v));

      if (params.has('x')) document.getElementById('xSlider').value = clamp(parseFloat(params.get('x')));
      if (params.has('y')) document.getElementById('ySlider').value = clamp(parseFloat(params.get('y')));
      if (params.has('z')) document.getElementById('zSlider').value = clamp(parseFloat(params.get('z')));

      if (params.get('from') === 'quiz') {
        const banner = document.getElementById('quizBanner');
        if (banner) banner.style.display = 'flex';
      }
    })();

    // Mobile UI toggle
    (function () {
      const toggle = document.getElementById('uiToggle');
      const ui = document.getElementById('ui');
      if (!toggle || !ui) return;

      let collapsed = false;

      toggle.addEventListener('click', () => {
        collapsed = !collapsed;
        ui.classList.toggle('ui--collapsed', collapsed);
        toggle.setAttribute('aria-expanded', !collapsed);
        toggle.querySelector('.ui-toggle-label').textContent = collapsed ? 'Controls' : 'Hide';
      });
    })();
  </script>
</Layout>

<style>
  canvas {
    position: fixed;
    top: 0;
    left: 0;
    background: #0d0d0d;
    width: 100%;
    height: 100%;
  }

  .tool-back-link {
    position: fixed;
    top: 1rem;
    right: 1.25rem;
    z-index: 90;
    background: rgba(15, 15, 26, 0.8);
    backdrop-filter: blur(8px);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 0.375rem 0.875rem;
    color: var(--color-muted);
    text-decoration: none;
    font-size: 0.8rem;
    transition: color 0.15s;
  }

  /* Desktop: fixed panel top-left */
  #ui {
    position: fixed;
    top: 1.25rem;
    left: 1.25rem;
    width: 280px;
    max-height: calc(100vh - 2.5rem);
    overflow-y: auto;
    background: rgba(7, 7, 16, 0.82);
    padding: 1rem;
    border-radius: 0.875rem;
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.07);
    z-index: 10;
  }

  .ui-handle { display: none; }
  .ui-toggle { display: none; }

  .control {
    margin-bottom: 12px;
  }

  .control label {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.7);
    display: block;
    margin-bottom: 3px;
  }

  .control.buttons {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  input[type='range'] {
    width: 100%;
    accent-color: #818cf8;
  }

  button {
    width: 48%;
    padding: 0.4rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.5rem;
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
    cursor: pointer;
    font-size: 0.8rem;
    transition: background 0.15s;
  }

  button:hover {
    background: rgba(255, 255, 255, 0.12);
  }

  .info {
    margin-top: 0.75rem;
    font-size: 0.75rem;
    opacity: 0.85;
    line-height: 1.7;
  }

  .ui-hints {
    margin-top: 0.75rem;
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.25);
    line-height: 1.5;
  }

  /* ─── Mobile: bottom sheet ─────────────────────── */
  @media (max-width: 767px) {
    .tool-back-link {
      top: auto;
      bottom: 1rem;
      right: 1rem;
      font-size: 0.75rem;
      padding: 0.3rem 0.7rem;
    }

    .ui-toggle {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      position: fixed;
      bottom: 1rem;
      left: 1rem;
      z-index: 20;
      background: rgba(129, 140, 248, 0.9);
      backdrop-filter: blur(8px);
      border: none;
      border-radius: 2rem;
      padding: 0.5rem 1rem;
      color: #fff;
      font-size: 0.8rem;
      font-weight: 600;
      cursor: pointer;
      width: auto;
    }

    .ui-toggle-icon {
      font-size: 0.95rem;
    }

    #ui {
      top: auto;
      left: 0;
      right: 0;
      bottom: 0;
      width: 100%;
      max-height: 55vh;
      border-radius: 1rem 1rem 0 0;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-bottom: none;
      padding: 0.5rem 1rem 1.5rem;
      transition: transform 0.3s ease;
      transform: translateY(0);
    }

    #ui.ui--collapsed {
      transform: translateY(100%);
    }

    .ui-handle {
      display: block;
      width: 36px;
      height: 4px;
      background: rgba(255, 255, 255, 0.2);
      border-radius: 2px;
      margin: 0.4rem auto 0.75rem;
    }

    .ui-hints {
      display: none;
    }
  }
</style>
